<link name="wheel_back_left_link">

  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.37699111843077493"/>
    <inertia ixx="0.001" iyy="0.001" izz="0.001"
             ixy="0" ixz="0" iyz="0"/>
  </inertial>

  <visual>
    <geometry>
      <cylinder radius="0.1" length="0.1"/>
    </geometry>
    <material name="brown"/>
  </visual>

  <collision>
    <geometry>
      <cylinder radius="0.1" length="0.1"/>
    </geometry>
    <surface>
  <friction>
    <ode>
      <mu>1.2</mu>
      <mu2>1.2</mu2>
    </ode>
  </friction>

  <bounce>
    <restitution_coefficient>0.2</restitution_coefficient>
  </bounce>
</surface>
  </collision>

</link>

