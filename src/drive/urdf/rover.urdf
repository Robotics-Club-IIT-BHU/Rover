    </geometry>
    <material name="silver"/>
  </visual>

  <collision>
    <origin xyz="0 0 0.0125" rpy="0 0 0"/>
    <geometry>
      <box size="0.025 0.73 0.025"/>
    </geometry>
  </collision>

</link>

