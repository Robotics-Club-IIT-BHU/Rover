<robot name="rover">
  <material name="silver">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>

  <link name="base_link">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.783699848541888"/>
      <inertia
        ixx="0.4116"
        iyy="0.8034"
        izz="1.0141"
        ixy="0.0"
        ixz="0.0"
        iyz="0.0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.85 0.65 0.20"/>
      </geometry>
      <material name="silver"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.85 0.65 0.20"/>
      </geometry>
    </collision>

  </link>

